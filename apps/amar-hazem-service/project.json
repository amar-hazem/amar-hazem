{
  "projectType": "application",
  "root": "apps/amar-hazem-service",
  "sourceRoot": "apps/amar-hazem-service/src",
  "tags": [],
  "targets": {
    "build": {
      "configurations": {
        "production": {
          "extractLicenses": true,
          "fileReplacements": [
            {
              "replace": "apps/amar-hazem-service/src/environments/environment.ts",
              "with": "apps/amar-hazem-service/src/environments/environment.prod.ts"
            }
          ],
          "inspect": false,
          "optimization": true
        }
      },
      "executor": "@nrwl/node:webpack",
      "options": {
        "assets": ["apps/amar-hazem-service/src/assets"],
        "main": "apps/amar-hazem-service/src/main.ts",
        "outputPath": "dist/apps/amar-hazem-service",
        "tsConfig": "apps/amar-hazem-service/tsconfig.app.json"
      },
      "outputs": ["{options.outputPath}"]
    },
    "serve": {
      "executor": "@nrwl/node:node",
      "options": {
        "buildTarget": "amar-hazem-service:build"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": ["apps/amar-hazem-service/**/*.ts"]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "options": {
        "jestConfig": "apps/amar-hazem-service/jest.config.js",
        "passWithNoTests": true
      },
      "outputs": ["coverage/apps/amar-hazem-service"]
    }
  }
}
