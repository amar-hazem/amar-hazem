{
  "implicitDependencies": ["amar-hazem-web"],
  "projectType": "application",
  "root": "apps/amar-hazem-web-e2e",
  "sourceRoot": "apps/amar-hazem-web-e2e/src",
  "tags": [],
  "targets": {
    "e2e": {
      "configurations": {
        "production": {
          "devServerTarget": "amar-hazem-web:serve:production"
        }
      },
      "executor": "@nrwl/cypress:cypress",
      "options": {
        "cypressConfig": "apps/amar-hazem-web-e2e/cypress.json",
        "devServerTarget": "amar-hazem-web:serve:development"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": ["apps/amar-hazem-web-e2e/**/*.{js,ts}"]
      },
      "outputs": ["{options.outputFile}"]
    }
  }
}
