{
  "$schema": "../../node_modules/@angular/service-worker/config/schema.json",
  "assetGroups": [
    {
      "installMode": "prefetch",
      "name": "app",
      "resources": {
        "files": ["/*.css", "/*.js", "/favicon.ico", "/index.html", "/manifest.webmanifest"]
      }
    },
    {
      "installMode": "lazy",
      "name": "assets",
      "resources": {
        "files": ["/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)", "/assets/**"]
      },
      "updateMode": "prefetch"
    }
  ],
  "index": "/index.html"
}
