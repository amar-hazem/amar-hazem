{
  "affected": {
    "defaultBase": "main"
  },
  "cli": {
    "defaultCollection": "@nrwl/angular"
  },
  "defaultProject": "amar-hazem-web",
  "generators": {
    "@nrwl/angular:application": {
      "e2eTestRunner": "cypress",
      "linter": "eslint",
      "style": "scss",
      "unitTestRunner": "jest"
    },
    "@nrwl/angular:component": {
      "style": "scss"
    },
    "@nrwl/angular:library": {
      "linter": "eslint",
      "unitTestRunner": "jest"
    }
  },
  "implicitDependencies": {
    ".eslintrc.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    }
  },
  "npmScope": "dollop",
  "targetDependencies": {
    "build": [
      {
        "projects": "dependencies",
        "target": "build"
      }
    ]
  },
  "tasksRunnerOptions": {
    "default": {
      "options": {
        "accessToken": "ZmQ2ZDFmMzUtYWQxZC00ZDAwLWI3OGMtYmUwNzBjNmQwNTMwfHJlYWQtd3JpdGU=",
        "cacheableOperations": ["build", "e2e", "lint", "test"]
      },
      "runner": "@nrwl/nx-cloud"
    }
  }
}
